{
  "name": "mall-velocity-fe",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "cross-env ENV_NAME=dev vite",
    "start:fat": "cross-env ENV_NAME=fat vite",
    "start:uat": "cross-env ENV_NAME=uat vite",
    "build": "cross-env NODE_OPTIONS=--max_old_space_size=4096 vite build",
    "build:fat": "cross-env NODE_OPTIONS=--max_old_space_size=4096 ENV_NAME=fat vite build",
    "build:uat": "cross-env NODE_OPTIONS=--max_old_space_size=4096 ENV_NAME=uat vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,tsx,ts,less,md,json}": [
      "prettier --write"
    ],
    "src/**/*.{js,ts,jsx,tsx}": [
      "eslint --no-inline-config --ext .js,.jsx,.ts,.tsx"
    ]
  },
  "dependencies": {
    "@woulsl-tools/sensors": "^1.2.6",
    "@woulsl/sentry-config": "^0.7.3",
    "antd-mobile": "^5.39.0",
    "autoprefixer": "^10.4.21",
    "eruda": "^3.4.1",
    "jojo-plugin-istanbul-vite": "^1.1.5",
    "js-cookie": "^3.0.5",
    "query-string": "^9.1.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@rollup/plugin-url": "^8.0.2",
    "@testing-library/dom": "^9.2.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.1",
    "@types/js-cookie": "^3.0.6",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-legacy": "^6.1.1",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-import": "^1.13.8",
    "consola": "^3.4.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "install": "^0.13.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "jsdom": "^26.1.0",
    "less": "^4.3.0",
    "lint-staged": "^15.5.1",
    "postcss-px-to-viewport": "^1.1.1",
    "prettier": "^3.5.3",
    "ts-jest": "^29.1.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1"
  }
}
